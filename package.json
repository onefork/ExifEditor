{
  "name": "exif-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173 --host",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "apk:debug": "npm run cap:sync && cd android && ./gradlew assembleDebug",
    "apk:release": "npm run cap:sync && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "jszip": "^3.10.1",
    "piexifjs": "^1.0.6"
  },
  "devDependencies": {
    "vite": "^5.4.2"
  }
}
