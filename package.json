{
  "name": "exif-editor",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "description": "图片信息编辑器 — 批量修改 EXIF 元数据，核心与界面分离支持多平台分发",
  "exports": {
    "./core": "./src/core/index.js",
    "./core/*": "./src/core/*",
    "./platform/*": "./src/platform/*"
  },
  "bin": {
    "exif-editor": "./src/app/cli.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build --mode web",
    "build:capacitor": "vite build",
    "build:vue": "vite build --mode vue",
    "build:react": "vite build --mode react",
    "build:cli": "echo 'CLI runs directly via node, no build step needed'",
    "build:api": "echo 'API runs directly via node, no build step needed'",
    "preview": "vite preview --port 4173 --host",
    "start:cli": "node src/app/cli.js",
    "start:api": "node src/app/api.js",
    "start:electron": "electron src/app/electron-main.js",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "apk:debug": "npm run cap:sync && cd android && ./gradlew assembleDebug",
    "apk:release": "npm run cap:sync && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.29",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "jszip": "^3.10.1",
    "piexifjs": "^1.0.6"
  },
  "optionalDependencies": {
    "@inquirer/prompts": "^8.5.2",
    "electron": "^43.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "vite": "^8.1.4"
  }
}
